# OpenRouter API key — get yours at https://openrouter.ai/settings/keys
OPENROUTER_API_KEY=sk-or-...

# Model to use for the HITL orchestrator (default: openai/gpt-4o-mini)
HITL_MODEL=openai/gpt-4o-mini

# HTTP server port (default: 3456)
PORT=3456

# Secret token for authenticating requests from the Python pipeline
HITL_API_SECRET=change-me-in-production
