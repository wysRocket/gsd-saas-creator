# Google Cloud / Gemini
GEMINI_API_KEY=
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=global
GOOGLE_GENAI_USE_VERTEXAI=True

# GitHub (for board reads, repo creation, Actions monitoring)
GITHUB_TOKEN=
GITHUB_ORG=SaaS-Pretty-Projects

# Firebase deployment
FIREBASE_TOKEN=
FIREBASE_PROJECT_ID=

# Stitch MCP
STITCH_MCP_ENDPOINT=http://136.111.153.224:8080
STITCH_API_KEY=

# Pipeline: path to the gsd-saas-creator repo root (used for script calls)
PIPELINE_REPO_ROOT=../..  # relative to agents/saas-pipeline/

# Path where generated product repos are written
PIPELINE_OUTPUT_DIR=../../output

# HITL approver service (see agents/hitl-approver/)
# Set HITL_APPROVER_URL to the running hitl-approver instance
HITL_APPROVER_URL=http://localhost:3456
# If set, all requests to the hitl-approver must include this as a Bearer token
HITL_API_SECRET=
# How often (seconds) to poll for a human decision
HITL_POLL_INTERVAL_SECONDS=10
# Maximum time (seconds) to wait for a human decision before timing out
HITL_POLL_TIMEOUT_SECONDS=3600
